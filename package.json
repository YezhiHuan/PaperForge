{
  "name": "paperforge",
  "version": "2.2.2",
  "private": true,
  "type": "module",
  "bin": {
    "paperforge": "./scripts/paperforge.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "paperforge:init": "node scripts/paperforge.mjs init",
    "paperforge:model:add": "node scripts/paperforge.mjs model add",
    "paperforge:model:list": "node scripts/paperforge.mjs model list",
    "paperforge:model:set-default": "node scripts/paperforge.mjs model set-default",
    "paperforge:model:remove": "node scripts/paperforge.mjs model remove"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
